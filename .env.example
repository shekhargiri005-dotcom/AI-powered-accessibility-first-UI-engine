# ══════════════════════════════════════════════════════════════════════════════
#  AI-Powered Accessibility-First UI Engine — Environment Variables
#  Copy to .env.local and fill in values. NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── ① Owner Authentication ────────────────────────────────────────────────────
#  Single-owner gate. Only this email + password can access the engine.
#  Generate hash: node scripts/generate-hash.js
#
OWNER_EMAIL="your-email@example.com"
OWNER_NAME="Your Name"
OWNER_PASSWORD_HASH="$2b$12$REPLACE_WITH_OUTPUT_FROM_generate-hash_SCRIPT"

# ── Next-Auth Secret (required in production) ─────────────────────────────────
#  Generate: openssl rand -base64 32
AUTH_SECRET="replace_with_a_random_32_char_secret_here_____"

# ══════════════════════════════════════════════════════════════════════════════
#  ② AI Provider API Keys  (24 Models across 9 providers)
#  Leave a key blank to disable that provider in the engine.
# ══════════════════════════════════════════════════════════════════════════════

# ── OPENAI  ───────────────────────────────────────────────────────────────────
#  Models powered by this key:
#    • gpt-4o               (flagship, best quality)
#    • gpt-4o-mini          (fast + cheap)
#    • o3-mini              (reasoning)
#    • o1-mini              (reasoning, compact)
#  Get key: https://platform.openai.com/api-keys
#
OPENAI_API_KEY="sk-proj-..."

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
#  Models powered by this key:
#    • claude-sonnet-4-5         (latest sonnet, balanced)
#    • claude-3-5-haiku-20241022 (fast, lightweight)
#    • claude-3-opus-20240229    (most capable)
#  Get key: https://console.anthropic.com/settings/keys
#
ANTHROPIC_API_KEY="sk-ant-..."

# ── GOOGLE / GEMINI ───────────────────────────────────────────────────────────
#  Models powered by this key:
#    • gemini-2.0-flash          (latest, fast multimodal)
#    • gemini-1.5-pro            (long context, powerful)
#    • gemini-1.5-flash          (fast + efficient)
#  Get key: https://aistudio.google.com/app/apikey
#
GOOGLE_API_KEY="AIzaSy..."
# Alias (either works, Google adapter checks both):
# GEMINI_API_KEY="AIzaSy..."

# ── Embeddings (pgvector / semantic knowledge search) ───────────────────────
#  Uses the GOOGLE_API_KEY above to call text-embedding-004.
#  Embedding dimensions must match the vector(768) column in the DB.
#
EMBEDDING_DIMS=768

# ── DEEPSEEK ──────────────────────────────────────────────────────────────────
#  Models powered by this key:
#    • deepseek-chat             (general purpose, v3)
#    • deepseek-coder            (code-specialised)
#  Get key: https://platform.deepseek.com/api_keys
#
DEEPSEEK_API_KEY="sk-..."

# ── GROQ  (OpenAI-compatible, blazing-fast inference) ─────────────────────────
#  Models powered by this key:
#    • llama-3.3-70b-versatile   (Meta/Llama via Groq)
#    • gemma2-9b-it              (Gemma via Groq)
#    • mixtral-8x7b-32768        (Mistral/Mixtral via Groq)
#  Get key: https://console.groq.com/keys
#  ⚠  GROQ_API_KEY is also the fallback for MetaAdapter + GemmaAdapter
#
GROQ_API_KEY="gsk_..."

# ── TOGETHER AI  (OpenAI-compatible, open-model hosting) ──────────────────────
#  Models powered by this key:
#    • meta-llama/Llama-3.3-70B-Instruct   (Meta via Together)
#    • meta-llama/Llama-3.1-8B-Instruct    (Meta via Together)
#    • mistralai/Mixtral-8x7B-Instruct-v0.1
#    • Qwen/Qwen2.5-Coder-32B-Instruct     (Qwen via Together)
#    • google/gemma-2-27b-it               (Gemma via Together)
#  Get key: https://api.together.xyz/settings/api-keys
#  ⚠  TOGETHER_API_KEY is the fallback for MetaAdapter, MistralAdapter,
#     QwenAdapter, and GemmaAdapter if their native keys are absent.
#
TOGETHER_API_KEY="..."

# ── MISTRAL AI  (native Mistral endpoint) ─────────────────────────────────────
#  Models powered by this key:
#    • mistral-large-latest      (flagship)
#    • mistral-small-latest      (fast, cheap)
#    • codestral-latest          (code-specialised)
#  Get key: https://console.mistral.ai/api-keys
#
MISTRAL_API_KEY="..."

# ── DASHSCOPE / ALIBABA CLOUD  (Qwen native endpoint) ────────────────────────
#  Models powered by this key:
#    • qwen-turbo                (fast, cost-effective)
#    • qwen-plus                 (balanced)
#    • qwen-coder-turbo          (code-specialised)
#  Get key: https://dashscope.aliyun.com/
#
DASHSCOPE_API_KEY="sk-..."

# ── OPENROUTER  (unified gateway — any model via one key) ─────────────────────
#  Lets you access OpenAI, Anthropic, Meta, Mistral, etc. through one API.
#  Set provider="openrouter" and use any OpenRouter model slug.
#  Get key: https://openrouter.ai/keys
#
OPENROUTER_API_KEY="sk-or-..."

# ══════════════════════════════════════════════════════════════════════════════
#  ③ Local / Self-Hosted Models  (no key needed)
# ══════════════════════════════════════════════════════════════════════════════

# ── OLLAMA  (local/remote Ollama server) ─────────────────────────────────────
#  Example models (must be pulled first:  ollama pull <model>):
#    • llama3.2           ollama pull llama3.2
#    • codellama          ollama pull codellama
#    • qwen2.5-coder      ollama pull qwen2.5-coder
#    • mistral            ollama pull mistral
#    • phi4               ollama pull phi4
#    • deepseek-coder     ollama pull deepseek-coder
#
#  For Vercel deployment: set OLLAMA_BASE_URL to your remote Ollama server URL.
#  Local Ollama (localhost:11434) is NOT reachable from Vercel serverless —
#  you need a publicly accessible server or tunnel.
#
OLLAMA_BASE_URL="http://localhost:11434/v1"
#
#  Optional: Set OLLAMA_API_KEY if your remote Ollama server requires auth.
#  Most local Ollama installations don't need a key.
# OLLAMA_API_KEY="your-ollama-key"

# ── LM STUDIO  (local LM Studio server) ──────────────────────────────────────
#  Set provider="lmstudio" in the engine config panel.
#  LM_STUDIO_BASE_URL is used if you override the default.
#
# LM_STUDIO_BASE_URL="http://localhost:1234/v1"

# ══════════════════════════════════════════════════════════════════════════════
#  ④ Pipeline Agent Model Overrides  (optional)
#  These let you pin specific models for each agent role.
#  Leave blank to let the engine pick from the user's active config.
# ══════════════════════════════════════════════════════════════════════════════

# CLASSIFIER_MODEL="gpt-4o-mini"         # Intent classification agent
# THINKING_MODEL="claude-sonnet-4-5"     # Thinking/planning agent
# REVIEW_MODEL="gpt-4o"                  # A11y review agent
# REPAIR_MODEL="gpt-4o"                  # Code repair agent

# ══════════════════════════════════════════════════════════════════════════════
#  ⑤ Infrastructure
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
#  Get from: https://console.neon.tech → Project → Connection Details → Prisma
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Redis / Upstash Cache ─────────────────────────────────────────────────────
#  Get from: https://console.upstash.com → Database → REST API tab
#  Leave empty in local dev to use in-memory LRU cache (no Redis needed).
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# ── Encryption Secret ─────────────────────────────────────────────────────────
#  Must be exactly 32 characters. Used to encrypt stored workspace API keys.
#  Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64').slice(0,32))"
ENCRYPTION_SECRET="replace_with_32_char_random_secret_here_____"
