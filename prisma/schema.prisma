generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTH.JS MODELS ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Multi-tenancy: A user can belong to multiple workspaces
  memberships   WorkspaceMember[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── MULTI-TENANCY CORE ───────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      WorkspaceMember[]
  settings     WorkspaceSettings[]
  projects     Project[]
  usageLogs    UsageLog[]
  feedbacks    GenerationFeedback[]
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ─── ORIGINAL SETTINGS (REFACtORED FOR WORKSPACE LINK) ───────────────────────

model WorkspaceSettings {
  id              String   @id @default(cuid())
  workspaceId     String
  provider        String
  model           String?
  encryptedApiKey String
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
}

model UsageLog {
  id               String   @id @default(cuid())
  workspaceId      String?
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  latencyMs        Int      @default(0)
  costUsd          Float    @default(0)
  cached           Boolean  @default(false)
  createdAt        DateTime @default(now())

  workspace        Workspace? @relation(fields: [workspaceId], references: [id])
}

// ─── FEEDBACK LOOP ────────────────────────────────────────────────────────────

enum FeedbackSignal {
  thumbs_up
  thumbs_down
  corrected
  discarded
}

model GenerationFeedback {
  id             String         @id @default(cuid())
  generationId   String                        // MemoryEntry.id from history.json
  workspaceId    String?
  provider       String
  model          String
  intentType     String                        // e.g. "dashboard", "landing_page"
  promptHash     String                        // first 16 chars of sha256(prompt)
  signal         FeedbackSignal
  correctionNote String?        @db.Text       // free-text description of what was wrong
  correctedCode  String?        @db.Text       // the version user saved / Sandpack edit
  a11yScore      Int            @default(0)
  critiqueScore  Int            @default(0)
  latencyMs      Int            @default(0)
  createdAt      DateTime       @default(now())

  workspace      Workspace?     @relation(fields: [workspaceId], references: [id])
}

// ─── PROJECT PERSISTENCE (replaces read-only filesystem JSON store) ───────────

model Project {
  id             String           @id
  name           String
  componentType  String           @default("component")
  workspaceId    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  currentVersion Int              @default(1)

  versions   ProjectVersion[]
  workspace  Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model ProjectVersion {
  id                String   @id @default(cuid())
  projectId         String
  version           Int
  timestamp         DateTime @default(now())
  code              String   @db.Text
  intent            Json
  a11yReport        Json
  thinkingPlan      Json?
  reviewData        Json?
  changeDescription String   @default("")
  linesChanged      Int      @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
}

// ─── VECTOR EMBEDDINGS (pgvector) ─────────────────────────────────────────────
// Similarity queries are run via raw SQL (@neondatabase/serverless),
// because Prisma has no native vector type yet.
// Embedding dims: 768 (Google text-embedding-004 model).

model ComponentEmbedding {
  id          String   @id @default(cuid())
  /// Matches knowledge chunk id, e.g. "registry:Sidebar", "template:dashboard", "blueprint:landing-page"
  knowledgeId String   @unique
  name        String
  keywords    String[]
  guidelines  String   @db.Text
  /// source — enables filtered retrieval by knowledge domain.
  /// Values: 'template' | 'registry' | 'blueprint' | 'motion' | 'feedback' | 'repair'
  source      String   @default("template")
  /// vector(768) — stored via raw SQL; Prisma treats as Unsupported
  embedding   Unsupported("vector(768)")?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeedbackEmbedding {
  id             String   @id @default(cuid())
  /// Links to GenerationFeedback.id (string UUID from feedbackStore)
  feedbackId     String   @unique
  intentType     String
  correctedCode  String   @db.Text
  correctionNote String?  @db.Text
  a11yScore      Int      @default(0)
  /// vector(768) — stored via raw SQL; Prisma treats as Unsupported
  embedding      Unsupported("vector(768)")?
  createdAt      DateTime @default(now())
}
